<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Cross.ErrorHandlers</id>
    <version>0.0.0</version>
    <authors>denis-peshkov</authors>
    <owners>denis-peshkov</owners>
    <copyright>Copyright 2026 Denis Peshkov</copyright>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectUrl>https://github.com/denis-peshkov/Cross.ErrorHandlers</projectUrl>
    <repository type="git" url="https://github.com/denis-peshkov/Cross.ErrorHandlers" />
    <readme>docs\README.md</readme>
    <icon>icon.png</icon>
    <releaseNotes>
      Initial version.
    </releaseNotes>
    <description>
      A .NET library providing unified error handling for ASP.NET Core applications. The package implements middleware that catches exceptions and transforms them into standardized JSON responses with proper HTTP status codes.

      Key Features:
      - Global exception handling middleware
      - Standardized error response format
      - Built-in support for common exception types
      - Request correlation tracking
      - Configurable stack trace visibility
      - Consistent logging

      Designed to streamline error handling across microservices and web applications while maintaining proper error tracking and debugging capabilities.
    </description>
    <tags>dotnet aspnetcore middleware error-handling exception-handling error-middleware csharp json microservices logging correlation-id nuget-package error-tracking debugging web-api</tags>
    <dependencies>
      <dependency id="FluentValidation" version="11.8.0" />
      <dependency id="MediatR.Contracts" version="2.0.1" />
      <dependency id="Microsoft.AspNetCore.Http.Abstractions" version="2.3.9" />
      <dependency id="Microsoft.Extensions.Configuration.Abstractions" version="8.0.0" />
      <dependency id="Microsoft.Extensions.Configuration.Binder" version="8.0.2" />
      <dependency id="Microsoft.Extensions.DependencyInjection" version="8.0.1" />
      <dependency id="Microsoft.Extensions.Hosting.Abstractions" version="8.0.1" />
      <dependency id="Microsoft.Extensions.Logging.Abstractions" version="8.0.2" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\Cross.ErrorHandlers\bin\Release\net6.0\Cross.ErrorHandlers*.* " target="lib\net6.0" />
    <file src="..\Cross.ErrorHandlers\bin\Release\net7.0\Cross.ErrorHandlers*.* " target="lib\net7.0" />
    <file src="..\Cross.ErrorHandlers\bin\Release\net8.0\Cross.ErrorHandlers*.* " target="lib\net8.0" />
    <file src="..\Cross.ErrorHandlers\bin\Release\net9.0\Cross.ErrorHandlers*.* " target="lib\net9.0" />
    <file src="..\Cross.ErrorHandlers\bin\Release\net10.0\Cross.ErrorHandlers*.* " target="lib\net10.0" />
    <file src="..\README.md" target="docs\" />
    <file src="..\icon.png" target="" />
  </files>
</package>
